<?xml version="1.0" encoding="utf-8"?>
<!-- Network security config -->
<!-- Allows cleartext (HTTP) traffic to all hosts. Required for: -->
<!--   - just_audio StreamAudioSource (localhost audio proxy) -->
<!--   - User-configured webhooks to private/LAN addresses (Home Assistant, -->
<!--     Node-RED, n8n, etc.) on 10.x, 192.168.x, 172.16-31.x ranges -->
<!-- HTTPS is still preferred and used for all first-party network calls. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
