    "whatsNewReachabilityTitle": "Reachability",
    "@whatsNewReachabilityTitle": {
        "description": "What's new feature title: Reachability"
    },
    "whatsNewReachabilityDescription": "Estimate how likely you are to reach each node on your mesh — without sending a single test packet.\\n\\nReachability passively observes traffic flowing through the network and assigns High, Medium, or Low confidence to every node. Find it in the drawer menu under Mesh.",
    "@whatsNewReachabilityDescription": {
        "description": "What's new description for Reachability feature"
    },
    "whatsNewVersion1100Subtitle": "Version 1.10.0",
    "@whatsNewVersion1100Subtitle": {
        "description": "What's new subtitle for version 1.10.0"
    },
    "whatsNewWorldMapTitle": "World Map",
    "@whatsNewWorldMapTitle": {
        "description": "What's new feature title: World Map"
    },
    "whatsNewWorldMapDescription": "See the entire global Meshtastic network on a single map. Every dot is a node sharing its location — zoom, pan, and tap to explore node details, hardware info, and last-seen times.\\n\\nNo connection required. The World Map pulls live data from the Socialmesh backend so you can explore the mesh anywhere.",
    "@whatsNewWorldMapDescription": {
        "description": "What's new description for World Map feature"
    },
    "whatsNewVersion1101Subtitle": "Version 1.10.1",
    "@whatsNewVersion1101Subtitle": {
        "description": "What's new subtitle for version 1.10.1"
    },
    "whatsNewPresenceTitle": "Presence",
    "@whatsNewPresenceTitle": {
        "description": "What's new feature title: Presence"
    },
    "whatsNewPresenceDescription": "See who is active on your mesh at a glance. Presence shows real-time node activity with intent indicators — whether someone is monitoring, mobile, or at a fixed base station.\\n\\nFilter by activity level, search by name, and tap any node to see their full profile. Find it in the drawer under Social.",
    "@whatsNewPresenceDescription": {
        "description": "What's new description for Presence feature"
    },
    "whatsNewVersion1110Subtitle": "Version 1.11.0",
    "@whatsNewVersion1110Subtitle": {
        "description": "What's new subtitle for version 1.11.0"
    },
    "whatsNewSignalsTitle": "Signals",
    "@whatsNewSignalsTitle": {
        "description": "What's new feature title: Signals"
    },
    "whatsNewSignalsDescription": "Broadcast ephemeral moments to your mesh. Signals are short-lived posts — share text, a photo, or your location with a TTL from 15 minutes up to 24 hours.\\n\\nNearby signals appear first with proximity badges showing hop count. When they fade, they are gone. True off-grid, ephemeral content.",
    "@whatsNewSignalsDescription": {
        "description": "What's new description for Signals feature"
    },
    "whatsNewVersion1130Subtitle": "Version 1.13.0",
    "@whatsNewVersion1130Subtitle": {
        "description": "What's new subtitle for version 1.13.0"
    },
    "whatsNewNodeDexTitle": "NodeDex",
    "@whatsNewNodeDexTitle": {
        "description": "What's new feature title: NodeDex"
    },
    "whatsNewNodeDexDescription": "A living field journal of the mesh world. Every node you discover is automatically recorded with a unique procedural Sigil and a personality Trait derived from real behavior.\\n\\nFind it in the drawer menu under Social. Filter by trait, search by name or hex ID, and tap any entry to explore its full profile — signal history, discovery timeline, and more.",
    "@whatsNewNodeDexDescription": {
        "description": "What's new description for NodeDex feature"
    },
    "whatsNewVersion1150Subtitle": "Version 1.15.0",
    "@whatsNewVersion1150Subtitle": {
        "description": "What's new subtitle for version 1.15.0"
    },
    "whatsNewAetherTitle": "Aether",
    "@whatsNewAetherTitle": {
        "description": "What's new feature title: Aether"
    },
    "whatsNewAetherDescription": "Track Meshtastic nodes at altitude! Schedule your flight with your mesh node and let ground stations around the world listen for your signal.\\n\\nAt 35,000 ft, LoRa can reach 400+ km. Report receptions, compete on the distance leaderboard, and set new range records. Find it in the drawer menu under Social.",
    "@whatsNewAetherDescription": {
        "description": "What's new description for Aether feature"
    },
    "whatsNewVersion1160Subtitle": "Version 1.16.0",
    "@whatsNewVersion1160Subtitle": {
        "description": "What's new subtitle for version 1.16.0"
    },
    "whatsNewTakGatewayTitle": "TAK Gateway",
    "@whatsNewTakGatewayTitle": {
        "description": "What's new feature title: TAK Gateway"
    },
    "whatsNewTakGatewayDescription": "Bridge your mesh into the Team Awareness Kit (TAK) ecosystem. Socialmesh now connects to a TAK Gateway via WebSocket and streams live Cursor-on-Target entities onto your map.\\n\\nEvery entity is colored by standard affiliation and given a dimension-specific icon. Filter by affiliation, search callsigns, track entities with a long-press, and tap any marker for full CoT details. Find it in the drawer menu under Mesh.",
    "@whatsNewTakGatewayDescription": {
        "description": "What's new description for TAK Gateway feature"
    },
